{
  "name": "fuelchef/fuelchef-subscription-box",
  "description": "A WooCommerce subscription box plugin for meal delivery services.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "wordpress-plugin",
    "woocommerce",
    "subscription",
    "meal-delivery"
  ],
  "homepage": "https://github.com/owaisahmed5300/fuelchef-subscription-box",
  "support": {
    "issues": "https://github.com/owaisahmed5300/fuelchef-subscription-box/issues",
    "source": "https://github.com/owaisahmed5300/fuelchef-subscription-box"
  },
  "authors": [
    {
      "name": "owaisahmed5300",
      "email": "owaisahmed5300@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "FuelChefSubsBox\\": "src/"
    }
  },
  "require": {
    "php": "^8.1",
    "mpdf/psr-log-aware-trait": "^2.0",
    "paypal/rest-api-sdk-php": "^1.14",
    "stripe/stripe-php": "^20.2"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "php-stubs/woocommerce-stubs": "^10.9",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0",
    "roave/security-advisories": "dev-latest",
    "sniccowp/php-scoper-wordpress-excludes": "^7.0",
    "squizlabs/php_codesniffer": "^3.13 || ^4.0",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.3"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.1"
    },
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "scripts": {
    "scope": [
      "find scripts/ -maxdepth 1 -type f -exec chmod +x {} +",
      "bash ./scripts/scope"
    ],
    "phpcs": "vendor/bin/phpcs --report=full",
    "phpcbf": "vendor/bin/phpcbf || true",
    "phpstan": "phpstan analyse --memory-limit=1024M",
    "lint": [
      "@phpcbf",
      "@phpcs",
      "@phpstan"
    ]
  },
  "scripts-descriptions": {
    "scope": "Scopes PHP code for WordPress compatibility.",
    "phpcbf": "Automatically fixes coding standard issues.",
    "phpcs": "Checks code against WordPress coding standards.",
    "phpstan": "Runs static analysis on the codebase.",
    "lint": "Runs full code quality checks (PHPCS, PHPCBF, PHPStan)."
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
