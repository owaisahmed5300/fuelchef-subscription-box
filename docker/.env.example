# ------------------------------------------------------------------
# Docker Compose project name — prevents inferring "docker" from the
# compose file directory. All resources use explicit names today, but
# this avoids surprises if a future service omits container_name.
# ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=fuelchef-subscription-box

# ------------------------------------------------------------------
# MySQL credentials (development only — do not use in production).
# ------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# ------------------------------------------------------------------
# Host port mappings (change if collisions occur).
# ------------------------------------------------------------------
WORDPRESS_PORT=8220
PMA_PORT=8221
MAILPIT_UI_PORT=8222
MAILPIT_SMTP_PORT=1031
DB_PORT=3445

# ------------------------------------------------------------------
# Docker build args (stable — override with care).
# ------------------------------------------------------------------
COMPOSER_VERSION=2
NODE_MAJOR=20
